{
  "name": "serena-openclaw-plugin",
  "version": "0.1.4",
  "description": "OpenClaw plugin that integrates Serena MCP for semantic code navigation and editing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/skill/SKILL.md",
    "src/skill/references",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": "2026.3.13",
      "minGatewayVersion": "2026.3.13",
      "builtWithOpenClawVersion": "2026.3.13"
    },
    "build": {
      "openclawVersion": "2026.3.13"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "prepublishOnly": "npm run check && npm test",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "serena",
    "mcp",
    "code-navigation",
    "semantic-editing"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "^5.8.3"
  }
}
